{
  "name": "os-scheduler-project",
  "private": true,
  "version": "0.0.0",
  "main": "dist-electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "package": "npm run build && electron-builder"
  },
  "devDependencies": {
    "autoprefixer": "^10.5.0",
    "electron": "^41.5.0",
    "electron-builder": "^24.13.3",
    "postcss": "^8.5.13",
    "tailwindcss": "^3.4.19",
    "typescript": "~6.0.2",
    "vite": "^8.0.10",
    "vite-plugin-electron": "^0.29.1"
  },
  "dependencies": {
    "axios": "^1.15.2"
  },
  "build": {
    "appId": "com.koreatech.os.scheduler",
    "productName": "OS-Scheduler-Project",
    "asar": false, 
    "directories": {
      "output": "release"
    },
    "win": {
      "target": ["dir", "nsis"],
      "requestedExecutionLevel": "requireAdministrator"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}